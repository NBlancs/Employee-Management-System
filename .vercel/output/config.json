{
  "version": 3,
  "overrides": {},
  "routes": [
    {
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "src": "/_nuxt/builds/meta/(.*)"
    },
    {
      "headers": {
        "cache-control": "public, max-age=1, immutable"
      },
      "src": "/_nuxt/builds/(.*)"
    },
    {
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "src": "/_nuxt/(.*)"
    },
    {
      "src": "/_nuxt/builds/meta(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "src": "/_nuxt/builds(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "src": "/_nuxt(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "(?<__isr_route>/__nuxt_error)",
      "dest": "/__fallback"
    },
    {
      "src": "/Transactions/transactions",
      "dest": "/Transactions/transactions"
    },
    {
      "src": "/Transactions",
      "dest": "/Transactions"
    },
    {
      "src": "/Main/main",
      "dest": "/Main/main"
    },
    {
      "src": "/Main",
      "dest": "/Main"
    },
    {
      "src": "/Landing/landing",
      "dest": "/Landing/landing"
    },
    {
      "src": "/Landing",
      "dest": "/Landing"
    },
    {
      "src": "/Employees/new-employee",
      "dest": "/Employees/new-employee"
    },
    {
      "src": "/Employees/employee-info",
      "dest": "/Employees/employee-info"
    },
    {
      "src": "/Employees/employee",
      "dest": "/Employees/employee"
    },
    {
      "src": "/Employees",
      "dest": "/Employees"
    },
    {
      "src": "/Departments/department-info",
      "dest": "/Departments/department-info"
    },
    {
      "src": "/Departments/department",
      "dest": "/Departments/department"
    },
    {
      "src": "/Departments",
      "dest": "/Departments"
    },
    {
      "src": "/Dashboard/dashboard",
      "dest": "/Dashboard/dashboard"
    },
    {
      "src": "/Dashboard",
      "dest": "/Dashboard"
    },
    {
      "src": "/Attendance/view-department-attendance",
      "dest": "/Attendance/view-department-attendance"
    },
    {
      "src": "/Attendance/shift-hours",
      "dest": "/Attendance/shift-hours"
    },
    {
      "src": "/Attendance/employee-attendance-summary",
      "dest": "/Attendance/employee-attendance-summary"
    },
    {
      "src": "/Attendance/attendance",
      "dest": "/Attendance/attendance"
    },
    {
      "src": "/Attendance",
      "dest": "/Attendance"
    },
    {
      "src": "/api/employees",
      "dest": "/api/employees"
    },
    {
      "src": "/__nuxt_error",
      "dest": "/__nuxt_error"
    },
    {
      "src": "/",
      "dest": "/index"
    },
    {
      "src": "/api/employees/(?<id>[^/]+)",
      "dest": "/api/employees/[id]"
    },
    {
      "src": "/api/?(?<path>.+)",
      "dest": "/api/[...path]"
    },
    {
      "src": "/__nuxt_island/(?:.*)",
      "dest": "/__nuxt_island/[...]"
    },
    {
      "src": "/(.*)",
      "dest": "/__fallback"
    }
  ]
}